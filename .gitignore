# Git ignore file for GraphNetExtractAgent

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Jupyter Notebook
.ipynb_checkpoints

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Project specific - Temporary files
temp/
temp/logs/
temp/batches/
*.tmp
*.log

# Project specific - Results (keep structure but not content)
results/*.json
results/*.txt
!results/.gitkeep

# Project specific - Archive (historical data)
archive/
!archive/.gitkeep

# Project specific - Data (large files)
data/*.txt
data/*.json
data/model_lists/*.txt
!data/.gitkeep
!data/model_lists/.gitkeep

# Project specific - Bad cases
bad_cases/*.json
!bad_cases/.gitkeep

# Project specific - Task tracking logs
task_tracking/archived/logs/*.txt
task_tracking/archived/logs/*.log

# HuggingFace cache
.huggingface/
*.cache

# Model files (large binaries)
*.bin
*.safetensors
*.pth
*.pt
*.h5
*.onnx
*.pb

# Workspace (extraction output)
workspace/
graph_net_workspace/
$GRAPH_NET_EXTRACT_WORKSPACE/

# Coordination temp files
*.coordination
coordination_*.txt
progress_*.txt
progress_*.log

# Empty files placeholder
EOF
